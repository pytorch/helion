@helion.kernel()
def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor, y: torch.Tensor) -> tuple[torch.Tensor, ...]:
    grad_x = torch.empty_like(x)
    grad_y = torch.empty_like(y)
    for tile in hl.tile(grad_x.shape):
