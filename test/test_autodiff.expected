    # src[helion_bwd_ffae9e580b6c.py:N]: x_tile = x[tile_0, tile_1, :]
    x_tile = tl.load(x + (indices_0[:, None, None] * 512 + indices_1[None, :, None] * 32 + indices_2[None, None, :] * 1), None)
    # src[helion_bwd_ffae9e580b6c.py:N]: neg_val = torch.neg(grad_out_tile)
    v_0 = -grad_out_tile
