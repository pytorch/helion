"""
Auto-generated Helion backward kernel.
"""

import torch
import helion
from helion import language as hl

@helion.kernel()
def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor) -> torch.Tensor:
    grad_x = torch.empty_like(x)
    _dim_0, _ = grad_x.shape
    for tile_0 in hl.tile(_dim_0):
        grad_out_tile = grad_out[tile_0]
        x_tile = x[tile_0, :]
        amax_val = torch.amax(x_tile, [-1])
        unsqueeze_val = amax_val.reshape(-1, 1)
        sub_val = torch.sub(x_tile, unsqueeze_val)
        exp_val = torch.exp(sub_val)
        sum_1_val = torch.sum(exp_val, [-1])
        div_val = torch.div(grad_out_tile, sum_1_val)
        unsqueeze_1_val = div_val.reshape(-1, 1)
        mul_val = torch.mul(unsqueeze_1_val, exp_val)
        neg_val = torch.neg(mul_val)
        sum_2_val = torch.sum(neg_val, [1], True)
        squeeze_val = sum_2_val.reshape(-1)
        add_1_val = torch.add(grad_out_tile, squeeze_val)
        view_val = add_1_val.reshape(-1, 1)
        view_1_val = amax_val.reshape(-1, 1)
        eq_val = torch.eq(view_1_val, x_tile)
        sum_3_val = torch.sum(eq_val, [-1], True)
        div_1_val = torch.div(view_val, sum_3_val)
        mul_1_val = torch.mul(div_1_val, eq_val)
        add_2_val = torch.add(mul_val, mul_1_val)
        grad_x[tile_0, :] = add_2_val
    return grad_x

