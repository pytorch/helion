"""
Auto-generated Helion backward kernel.
"""

import torch
import helion
from helion import language as hl

@helion.kernel()
def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor) -> torch.Tensor:
    grad_x = torch.empty_like(x)
    _dim_0, _ = grad_x.shape
    for tile_0 in hl.tile(_dim_0):
        grad_out_tile = grad_out[tile_0, :]
        x_tile = x[tile_0, :]
        mul_2_val = torch.mul(grad_out_tile, x_tile)
        mul_val = torch.mul(x_tile, x_tile)
        mean_val = torch.mean(mul_val, [-1])
        add_val = torch.add(mean_val, 1e-05)
        rsqrt_val = torch.rsqrt(add_val)
        unsqueeze_val = rsqrt_val.reshape(-1, 1)
        mul_3_val = torch.mul(grad_out_tile, unsqueeze_val)
        sum_1_val = torch.sum(mul_2_val, [1], True)
        squeeze_val = sum_1_val.reshape(-1)
        mul_4_val = torch.mul(squeeze_val, -0.5)
        pow_1_val = torch.pow(rsqrt_val, 3)
        mul_5_val = torch.mul(mul_4_val, pow_1_val)
        unsqueeze_1_val = mul_5_val.reshape(-1, 1)
        div_val = torch.div(unsqueeze_1_val, 32)
        mul_6_val = torch.mul(div_val, x_tile)
        add_1_val = torch.add(mul_3_val, mul_6_val)
        add_2_val = torch.add(add_1_val, mul_6_val)
        grad_x[tile_0, :] = add_2_val
    return grad_x

