_BLOCK_SIZE_0 = tl.constexpr(32)
_BLOCK_SIZE_1 = tl.constexpr(32)

@triton.jit
def _helion_backward_kernel(grad_out, x, grad_x):
    # src[helion_bwd_29d1e7a1feed.py:N]: for tile_0, tile_1 in hl.tile([_dim_0, _dim_1]):
    num_blocks_0 = tl.cdiv(32, _BLOCK_SIZE_0)
