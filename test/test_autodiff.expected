    # src[helion_bwd_29d1e7a1feed.py:N]: mul_1_val = torch.mul(neg_val, mul_val)
    v_4 = v_2 * v_3
    # src[helion_bwd_29d1e7a1feed.py:N]: grad_x[tile_0, tile_1] = mul_1_val
    tl.store(grad_x + (indices_0[:, None] * 64 + indices_1[None, :] * 1), v_4, None)

