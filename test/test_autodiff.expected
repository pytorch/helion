--- assertExpectedJournal(TestAutodiff.test_amax_reduction)
"""
Auto-generated Helion backward kernel.
"""

import torch
import helion
from helion import language as hl

@helion.kernel()
def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor) -> torch.Tensor:
    grad_x = torch.empty_like(x)
    _dim_0, _ = grad_x.shape
    for tile_0 in hl.tile(_dim_0):
        grad_out_tile = grad_out[tile_0]
        x_tile = x[tile_0, :]
        view_val = grad_out_tile.reshape(-1, 1)
        amax_val = torch.amax(x_tile, [-1])
        view_1_val = amax_val.reshape(-1, 1)
        eq_val = torch.eq(view_1_val, x_tile)
        sum_1_val = torch.sum(eq_val, [-1], True)
        div_val = torch.div(view_val, sum_1_val)
        mul_val = torch.mul(div_val, eq_val)
        grad_x[tile_0, :] = mul_val
    return grad_x

