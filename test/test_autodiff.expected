    v_4 = 0.0
    v_5 = tl.where(v_3, v_4, grad_out_tile)
    # src[helion_bwd_cfb9b7eac08f.py:N]: grad_x[tile] = where_val
    tl.store(grad_x + indices_0 * 1, v_5, None)

