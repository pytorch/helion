"""
Auto-generated Helion backward kernel.
"""

import torch
import helion
from helion import language as hl

@helion.kernel()
def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor) -> torch.Tensor:
    grad_x = torch.empty_like(x)
    _dim_0, _ = grad_x.shape
    for tile_0 in hl.tile(_dim_0):
        grad_out_tile = grad_out[tile_0, :]
        x_tile = x[tile_0, :]
        sum_1_val = torch.sum(x_tile, [-1])
        div_val = torch.div(sum_1_val, 32)
        unsqueeze_val = div_val.reshape(-1, 1)
        sub_val = torch.sub(x_tile, unsqueeze_val)
        mul_2_val = torch.mul(grad_out_tile, sub_val)
        mul_val = torch.mul(sub_val, sub_val)
        sum_2_val = torch.sum(mul_val, [-1])
        div_1_val = torch.div(sum_2_val, 32)
        add_val = torch.add(div_1_val, 1e-05)
        rsqrt_val = torch.rsqrt(add_val)
        unsqueeze_1_val = rsqrt_val.reshape(-1, 1)
        mul_3_val = torch.mul(grad_out_tile, unsqueeze_1_val)
        sum_3_val = torch.sum(mul_2_val, [1], True)
        squeeze_val = sum_3_val.reshape(-1)
        mul_4_val = torch.mul(squeeze_val, -0.5)
        pow_1_val = torch.pow(rsqrt_val, 3)
        mul_5_val = torch.mul(mul_4_val, pow_1_val)
        div_2_val = torch.div(mul_5_val, 32)
        unsqueeze_2_val = div_2_val.reshape(-1, 1)
        mul_6_val = torch.mul(unsqueeze_2_val, sub_val)
        add_1_val = torch.add(mul_3_val, mul_6_val)
        add_2_val = torch.add(add_1_val, mul_6_val)
        neg_val = torch.neg(add_2_val)
        sum_4_val = torch.sum(neg_val, [1], True)
        squeeze_1_val = sum_4_val.reshape(-1)
        div_3_val = torch.div(squeeze_1_val, 32)
        unsqueeze_3_val = div_3_val.reshape(-1, 1)
        add_3_val = torch.add(add_2_val, unsqueeze_3_val)
        grad_x[tile_0, :] = add_3_val
    return grad_x

