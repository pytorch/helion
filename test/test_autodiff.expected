import triton
import triton.language as tl
from helion.runtime import default_launcher as _default_launcher

_BLOCK_SIZE_0 = tl.constexpr(32)

@triton.jit
def _helion_backward_kernel(grad_out, x, grad_x, _RDIM_SIZE_1: tl.constexpr):
    # src[helion_bwd_bdd5d4453b0f.py:N]: for tile_0 in hl.tile(_dim_0):
    pid_0 = tl.program_id(0)
    offset_0 = pid_0 * _BLOCK_SIZE_0
    indices_0 = (offset_0 + tl.arange(0, _BLOCK_SIZE_0)).to(tl.int32)
    indices_1 = tl.arange(0, _RDIM_SIZE_1).to(tl.int32)
    # src[helion_bwd_bdd5d4453b0f.py:N]: grad_out_tile = grad_out[tile_0]
    grad_out_tile = tl.load(grad_out + indices_0 * 1, None)
    # src[helion_bwd_bdd5d4453b0f.py:N]: x_tile = x[tile_0, :]
    x_tile = tl.load(x + (indices_0[:, None] * 32 + indices_1[None, :] * 1), None)
    # src[helion_bwd_bdd5d4453b0f.py:N]: amax_val = torch.amax(x_tile, [-1])
    amax_val = tl.cast(tl.max(x_tile, 1), tl.float32)
    # src[helion_bwd_bdd5d4453b0f.py:N]: unsqueeze_val = amax_val.reshape(-1, 1)
    unsqueeze_val = tl.reshape(amax_val, [_BLOCK_SIZE_0, 1])
    # src[helion_bwd_bdd5d4453b0f.py:N]: sub_val = torch.sub(x_tile, unsqueeze_val)
    v_0 = x_tile - unsqueeze_val
    # src[helion_bwd_bdd5d4453b0f.py:N]: exp_val = torch.exp(sub_val)
    v_1 = libdevice.exp(v_0)
    # src[helion_bwd_bdd5d4453b0f.py:N]: sum_1_val = torch.sum(exp_val, [-1])
    sum_1_val = tl.cast(tl.sum(v_1, 1), tl.float32)
    # src[helion_bwd_bdd5d4453b0f.py:N]: div_val = torch.div(grad_out_tile, sum_1_val)
    v_2 = grad_out_tile / sum_1_val
    # src[helion_bwd_bdd5d4453b0f.py:N]: unsqueeze_1_val = div_val.reshape(-1, 1)
    unsqueeze_1_val = tl.reshape(v_2, [_BLOCK_SIZE_0, 1])
    # src[helion_bwd_bdd5d4453b0f.py:N]: mul_val = torch.mul(unsqueeze_1_val, exp_val)
    v_3 = unsqueeze_1_val * v_1
    # src[helion_bwd_bdd5d4453b0f.py:N]: neg_val = torch.neg(mul_val)
    v_4 = -v_3
    # src[helion_bwd_bdd5d4453b0f.py:N]: sum_2_val = torch.sum(neg_val, [1], True)
    sum_2_val = tl.cast(tl.reshape(tl.sum(v_4, 1), [_BLOCK_SIZE_0, 1]), tl.float32)
    # src[helion_bwd_bdd5d4453b0f.py:N]: squeeze_val = sum_2_val.reshape(-1)
    squeeze_val = tl.reshape(sum_2_val, [_BLOCK_SIZE_0])
    # src[helion_bwd_bdd5d4453b0f.py:N]: add_1_val = torch.add(grad_out_tile, squeeze_val)
    v_5 = grad_out_tile + squeeze_val
    # src[helion_bwd_bdd5d4453b0f.py:N]: view_val = add_1_val.reshape(-1, 1)
    view_val = tl.reshape(v_5, [_BLOCK_SIZE_0, 1])
    # src[helion_bwd_bdd5d4453b0f.py:N]: view_1_val = amax_val.reshape(-1, 1)
    view_1_val = tl.reshape(amax_val, [_BLOCK_SIZE_0, 1])
    # src[helion_bwd_bdd5d4453b0f.py:N]: eq_val = torch.eq(view_1_val, x_tile)
    v_6 = view_1_val == x_tile
    # src[helion_bwd_bdd5d4453b0f.py:N]: sum_3_val = torch.sum(eq_val, [-1], True)
    v_7 = tl.cast(v_6, tl.int64)
    sum_3_val = tl.cast(tl.reshape(tl.sum(v_7, 1), [_BLOCK_SIZE_0, 1]), tl.int64)
    # src[helion_bwd_bdd5d4453b0f.py:N]: div_1_val = torch.div(view_val, sum_3_val)
    v_8 = tl.cast(sum_3_val, tl.float32)
    v_9 = view_val / v_8
    # src[helion_bwd_bdd5d4453b0f.py:N]: mul_1_val = torch.mul(div_1_val, eq_val)
    v_10 = tl.cast(v_6, tl.float32)
    v_11 = v_9 * v_10
    # src[helion_bwd_bdd5d4453b0f.py:N]: add_2_val = torch.add(mul_val, mul_1_val)
    v_12 = v_3 + v_11
    # src[helion_bwd_bdd5d4453b0f.py:N]: grad_x[tile_0, :] = add_2_val
    tl.store(grad_x + (indices_0[:, None] * 32 + indices_1[None, :] * 1), v_12, None)

def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor, *, _launcher=_default_launcher):
    # src[helion_bwd_bdd5d4453b0f.py:N]: grad_x = torch.empty_like(x)
    grad_x = torch.empty_like(x)
    # src[helion_bwd_bdd5d4453b0f.py:N]: _dim_0, _ = grad_x.shape
    _dim_0, _ = grad_x.shape
    # src[helion_bwd_bdd5d4453b0f.py:N]: for tile_0 in hl.tile(_dim_0):
    _BLOCK_SIZE_0 = 32
    _RDIM_SIZE_1 = 32
    # src[helion_bwd_bdd5d4453b0f.py:N]: for tile_0 in hl.tile(_dim_0):
    # src[helion_bwd_bdd5d4453b0f.py:N]:     grad_out_tile = grad_out[tile_0]
    # src[helion_bwd_bdd5d4453b0f.py:N]:     x_tile = x[tile_0, :]
    # src[helion_bwd_bdd5d4453b0f.py:N-N]: ...
    _launcher(_helion_backward_kernel, (triton.cdiv(64, _BLOCK_SIZE_0),), grad_out, x, grad_x, _RDIM_SIZE_1, num_warps=4, num_stages=1)
    # src[helion_bwd_bdd5d4453b0f.py:N]: return grad_x
    return grad_x

