    # src[helion_bwd_29d1e7a1feed.py:N]: neg_val = torch.neg(grad_out_tile)
    v_2 = -grad_out_tile
    # src[helion_bwd_29d1e7a1feed.py:N]: mul_val = torch.mul(reciprocal_val, reciprocal_val)
