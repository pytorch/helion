"""
Auto-generated Helion backward kernel.
"""

import torch
import helion
from helion import language as hl

@helion.kernel()
def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor) -> torch.Tensor:
    grad_x = torch.empty_like(x)
    _dim_0, _dim_1, _ = grad_x.shape
    for tile_0, tile_1 in hl.tile([_dim_0, _dim_1]):
        grad_out_tile = grad_out[tile_0, tile_1, :]
        x_tile = x[tile_0, tile_1, :]
        neg_val = torch.neg(grad_out_tile)
        amax_val = torch.amax(x_tile, [-1], True)
        sub_val = torch.sub(x_tile, amax_val)
        exp_val = torch.exp(sub_val)
        sum_1_val = torch.sum(exp_val, [-1], True)
        div_1_val = torch.div(exp_val, sum_1_val)
        div_2_val = torch.div(div_1_val, sum_1_val)
        mul_val = torch.mul(neg_val, div_2_val)
        div_3_val = torch.div(grad_out_tile, sum_1_val)
        sum_2_val = torch.sum(mul_val, [2], True)
        add_val = torch.add(div_3_val, sum_2_val)
        mul_1_val = torch.mul(add_val, exp_val)
        neg_1_val = torch.neg(mul_1_val)
        sum_3_val = torch.sum(neg_1_val, [2], True)
        eq_val = torch.eq(amax_val, x_tile)
        sum_4_val = torch.sum(eq_val, [-1], True)
        div_4_val = torch.div(sum_3_val, sum_4_val)
        mul_2_val = torch.mul(div_4_val, eq_val)
        add_1_val = torch.add(mul_1_val, mul_2_val)
        grad_x[tile_0, tile_1, :] = add_1_val
    return grad_x

