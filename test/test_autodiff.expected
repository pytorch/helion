    _BLOCK_SIZE_0 = 32
    # src[helion_bwd_cfb9b7eac08f.py:N]: for tile in hl.tile(grad_x.shape):
    # src[helion_bwd_cfb9b7eac08f.py:N]:     grad_out_tile = grad_out[tile]
