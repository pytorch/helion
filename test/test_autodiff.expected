from __future__ import annotations

import torch
import triton
import triton.language as tl
from helion.runtime import default_launcher as _default_launcher

_BLOCK_SIZE_0 = tl.constexpr(32)

@triton.jit
def _helion_backward_kernel(grad_out, x, grad_x, _RDIM_SIZE_1: tl.constexpr):
    # src[helion_bwd_06cf26fe5e92.py:N]: for tile_0 in hl.tile(_dim_0):
    pid_0 = tl.program_id(0)
    offset_0 = pid_0 * _BLOCK_SIZE_0
    indices_0 = (offset_0 + tl.arange(0, _BLOCK_SIZE_0)).to(tl.int32)
    indices_1 = tl.arange(0, _RDIM_SIZE_1).to(tl.int32)
    # src[helion_bwd_06cf26fe5e92.py:N]: grad_out_tile = grad_out[tile_0, :]
    grad_out_tile = tl.load(grad_out + (indices_0[:, None] * 32 + indices_1[None, :] * 1), None)
    # src[helion_bwd_06cf26fe5e92.py:N]: x_tile = x[tile_0, :]
    x_tile = tl.load(x + (indices_0[:, None] * 32 + indices_1[None, :] * 1), None)
    # src[helion_bwd_06cf26fe5e92.py:N]: neg_val = torch.neg(grad_out_tile)
    v_0 = -grad_out_tile
    # src[helion_bwd_06cf26fe5e92.py:N]: amax_val = torch.amax(x_tile, [1], True)
    amax_val = tl.cast(tl.reshape(tl.max(x_tile, 1), [_BLOCK_SIZE_0, 1]), tl.float32)
    # src[helion_bwd_06cf26fe5e92.py:N]: sub_val = torch.sub(x_tile, amax_val)
    v_1 = x_tile - amax_val
    # src[helion_bwd_06cf26fe5e92.py:N]: exp_val = torch.exp(sub_val)
    v_2 = libdevice.exp(v_1)
    # src[helion_bwd_06cf26fe5e92.py:N]: sum_1_val = torch.sum(exp_val, [1], True)
    sum_1_val = tl.cast(tl.reshape(tl.sum(v_2, 1), [_BLOCK_SIZE_0, 1]), tl.float32)
    # src[helion_bwd_06cf26fe5e92.py:N]: div_1_val = torch.div(exp_val, sum_1_val)
    v_3 = v_2 / sum_1_val
    # src[helion_bwd_06cf26fe5e92.py:N]: div_2_val = torch.div(div_1_val, sum_1_val)
    v_4 = v_3 / sum_1_val
    # src[helion_bwd_06cf26fe5e92.py:N]: mul_val = torch.mul(neg_val, div_2_val)
    v_5 = v_0 * v_4
    # src[helion_bwd_06cf26fe5e92.py:N]: div_3_val = torch.div(grad_out_tile, sum_1_val)
    v_6 = grad_out_tile / sum_1_val
    # src[helion_bwd_06cf26fe5e92.py:N]: sum_2_val = torch.sum(mul_val, [1], True)
    sum_2_val = tl.cast(tl.reshape(tl.sum(v_5, 1), [_BLOCK_SIZE_0, 1]), tl.float32)
    # src[helion_bwd_06cf26fe5e92.py:N]: add_val = torch.add(div_3_val, sum_2_val)
    v_7 = v_6 + sum_2_val
    # src[helion_bwd_06cf26fe5e92.py:N]: mul_1_val = torch.mul(add_val, exp_val)
    v_8 = v_7 * v_2
    # src[helion_bwd_06cf26fe5e92.py:N]: neg_1_val = torch.neg(mul_1_val)
    v_9 = -v_8
    # src[helion_bwd_06cf26fe5e92.py:N]: sum_3_val = torch.sum(neg_1_val, [1], True)
    sum_3_val = tl.cast(tl.reshape(tl.sum(v_9, 1), [_BLOCK_SIZE_0, 1]), tl.float32)
    # src[helion_bwd_06cf26fe5e92.py:N]: eq_val = torch.eq(amax_val, x_tile)
    v_10 = amax_val == x_tile
    # src[helion_bwd_06cf26fe5e92.py:N]: sum_4_val = torch.sum(eq_val, [1], True)
    v_11 = tl.cast(v_10, tl.int64)
    sum_4_val = tl.cast(tl.reshape(tl.sum(v_11, 1), [_BLOCK_SIZE_0, 1]), tl.int64)
    # src[helion_bwd_06cf26fe5e92.py:N]: div_4_val = torch.div(sum_3_val, sum_4_val)
    v_12 = tl.cast(sum_4_val, tl.float32)
    v_13 = sum_3_val / v_12
    # src[helion_bwd_06cf26fe5e92.py:N]: mul_2_val = torch.mul(div_4_val, eq_val)
    v_14 = tl.cast(v_10, tl.float32)
    v_15 = v_13 * v_14
    # src[helion_bwd_06cf26fe5e92.py:N]: add_1_val = torch.add(mul_1_val, mul_2_val)
    v_16 = v_8 + v_15
    # src[helion_bwd_06cf26fe5e92.py:N]: grad_x[tile_0, :] = add_1_val
    tl.store(grad_x + (indices_0[:, None] * 32 + indices_1[None, :] * 1), v_16, None)

def backward_kernel(grad_out: torch.Tensor, x: torch.Tensor, *, _launcher=_default_launcher):
    # src[helion_bwd_06cf26fe5e92.py:N]: grad_x = torch.empty_like(x)
    grad_x = torch.empty_like(x)
    # src[helion_bwd_06cf26fe5e92.py:N]: _dim_0, _ = grad_x.shape
    _dim_0, _ = grad_x.shape
    # src[helion_bwd_06cf26fe5e92.py:N]: for tile_0 in hl.tile(_dim_0):
    _BLOCK_SIZE_0 = 32
    _RDIM_SIZE_1 = 32
    # src[helion_bwd_06cf26fe5e92.py:N]: for tile_0 in hl.tile(_dim_0):
    # src[helion_bwd_06cf26fe5e92.py:N]:     grad_out_tile = grad_out[tile_0, :]
    # src[helion_bwd_06cf26fe5e92.py:N]:     x_tile = x[tile_0, :]
    # src[helion_bwd_06cf26fe5e92.py:N-N]: ...
    _launcher(_helion_backward_kernel, (triton.cdiv(64, _BLOCK_SIZE_0),), grad_out, x, grad_x, _RDIM_SIZE_1, num_warps=4, num_stages=1)
    # src[helion_bwd_06cf26fe5e92.py:N]: return grad_x
    return grad_x

