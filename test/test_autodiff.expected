"""
Auto-generated Helion backward kernel.
"""

import torch
import helion
from helion import language as hl

@helion.kernel()
def backward_kernel(grad_out_0: torch.Tensor, grad_out_1: torch.Tensor, x: torch.Tensor, weight: torch.Tensor) -> tuple[torch.Tensor, ...]:
    grad_x = torch.empty_like(x)
    grad_weight = torch.empty_like(weight)
    _dim_0, _ = grad_x.shape
    _m_block = hl.register_block_size(_dim_0)
    _num_blocks = (_dim_0 + _m_block - 1) // _m_block
    grad_weight_parts = torch.empty([_num_blocks, weight.shape[0]], dtype=weight.dtype, device=weight.device)
    for tile_0 in hl.tile(_dim_0, block_size=_m_block):
        grad_out_0_tile = grad_out_0[tile_0, :]
        grad_out_1_tile = grad_out_1[tile_0]
        x_tile = x[tile_0, :]
        weight_tile = weight[:]
        mul_val = torch.mul(x_tile, x_tile)
        mean_val = torch.mean(mul_val, [-1])
        add_val = torch.add(mean_val, 1e-05)
        rsqrt_val = torch.rsqrt(add_val)
        unsqueeze_val = rsqrt_val.reshape(-1, 1)
        mul_1_val = torch.mul(x_tile, unsqueeze_val)
        mul_3_val = torch.mul(grad_out_0_tile, mul_1_val)
        mul_4_val = torch.mul(grad_out_0_tile, weight_tile)
        sum_1_val = torch.sum(mul_3_val, [0], True)
        view_val = sum_1_val.reshape(-1)
        mul_5_val = torch.mul(mul_4_val, x_tile)
        mul_6_val = torch.mul(mul_4_val, unsqueeze_val)
        sum_2_val = torch.sum(mul_5_val, [1], True)
        squeeze_val = sum_2_val.reshape(-1)
        add_1_val = torch.add(grad_out_1_tile, squeeze_val)
        mul_7_val = torch.mul(add_1_val, -0.5)
        pow_1_val = torch.pow(rsqrt_val, 3)
        mul_8_val = torch.mul(mul_7_val, pow_1_val)
        unsqueeze_1_val = mul_8_val.reshape(-1, 1)
        div_val = torch.div(unsqueeze_1_val, 32)
        mul_9_val = torch.mul(div_val, x_tile)
        add_2_val = torch.add(mul_6_val, mul_9_val)
        add_3_val = torch.add(add_2_val, mul_9_val)
        grad_x[tile_0, :] = add_3_val
        grad_weight_parts[tile_0.id, :] = view_val
    grad_weight = grad_weight_parts.sum(0)
    return (grad_x, grad_weight)

