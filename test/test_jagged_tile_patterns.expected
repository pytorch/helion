from __future__ import annotations

import torch
import helion
import triton
import triton.language as tl
from helion.runtime import default_launcher as _default_launcher

_BLOCK_SIZE_0 = tl.constexpr(1)
_BLOCK_SIZE_1 = tl.constexpr(32)
_BLOCK_SIZE_2 = tl.constexpr(32)
_BLOCK_SIZE_3 = tl.constexpr(32)

@triton.jit
def _helion_jagged_dense_bmm(seq_offsets, jagged, dense, bias, output, _group_tile_prefix, _NUM_SM: tl.constexpr, _TOTAL_TILES: tl.constexpr):
    # src[test_jagged_tile_patterns.py:N]: for tile_b in hl.tile(B):
    # src[test_jagged_tile_patterns.py:N]:     starts = seq_offsets[tile_b]
