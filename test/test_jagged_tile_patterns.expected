    for virtual_pid in tl.range(tl.program_id(0), _TOTAL_TILES, _NUM_SM):
        group_idx = 0
        for _scan in tl.range(0, 3):
            if tl.load(_group_tile_prefix + _scan + 1) <= virtual_pid:
                group_idx = _scan + 1
        local_tile = virtual_pid - tl.load(_group_tile_prefix + group_idx)
        offset_0 = group_idx
        # src[test_jagged_tile_patterns.py:N]: for tile_b in hl.tile(B):
        indices_0 = offset_0 + tl.zeros([1], tl.int32)
        # src[test_jagged_tile_patterns.py:N]: starts = seq_offsets[tile_b]
        starts = tl.load(seq_offsets + indices_0 * 1, None)
        # src[test_jagged_tile_patterns.py:N]: ends = seq_offsets[tile_b.index + 1]
        v_0 = 1
        v_1 = indices_0 + v_0
        ends = tl.load(seq_offsets + (indices_0 + 1) * 1, None)
        # src[test_jagged_tile_patterns.py:N]: seq_len = ends - starts
        v_2 = ends - starts
        # src[test_jagged_tile_patterns.py:N]: for tile_len in hl.jagged_tile(seq_len):
        # src[test_jagged_tile_patterns.py:N]:     jagged_indices = starts[:, None] + tile_len.index[None, :]
        # src[test_jagged_tile_patterns.py:N-N]: ...
        amax = tl.cast(tl.max(v_2, 0), tl.int64)
        # src[test_jagged_tile_patterns.py:N]: for tile_b in hl.tile(B):
        # src[test_jagged_tile_patterns.py:N]:     starts = seq_offsets[tile_b]
        # src[test_jagged_tile_patterns.py:N]:     ends = seq_offsets[tile_b.index + 1]
        # src[test_jagged_tile_patterns.py:N-N]: ...
        _m_size = tl.load(seq_offsets + group_idx + 1) - tl.load(seq_offsets + group_idx)
        _m_tiles = tl.cdiv(_m_size, _BLOCK_SIZE_1)
        offset_1 = local_tile % _m_tiles * _BLOCK_SIZE_1
        offset_2 = local_tile // _m_tiles * _BLOCK_SIZE_2
        # src[test_jagged_tile_patterns.py:N]: for tile_len in hl.jagged_tile(seq_len):
        # src[test_jagged_tile_patterns.py:N]:     jagged_indices = starts[:, None] + tile_len.index[None, :]
        # src[test_jagged_tile_patterns.py:N-N]: ...
        indices_1 = offset_1 + tl.arange(0, _BLOCK_SIZE_1).to(tl.int32)
        mask_1 = indices_1[None, :] < v_2[:, None]
        starts_copy = starts
        starts_copy_0 = starts_copy
        # src[test_jagged_tile_patterns.py:N]: jagged_indices = starts[:, None] + tile_len.index[None, :]
        subscript = starts_copy_0[:, None]
        subscript_1 = indices_1[None, :]
        v_3 = tl.cast(subscript_1, tl.int64)
        v_4 = subscript + v_3
        # src[test_jagged_tile_patterns.py:N]: for tile_k in hl.tile(0, K):
        # src[test_jagged_tile_patterns.py:N]:     acc = hl.zeros([tile_b, tile_len, tile_k], dtype=dtype, device=device)
        # src[test_jagged_tile_patterns.py:N]:     for tile_d in hl.tile(0, D):
        # src[test_jagged_tile_patterns.py:N-N]: ...
        indices_2 = offset_2 + tl.arange(0, _BLOCK_SIZE_2).to(tl.int32)
