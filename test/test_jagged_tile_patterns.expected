            # src[test_jagged_tile_patterns.py:N]:     [jagged_indices[:, :, None] * D + tile_d.index[None, None, :]],
            # src[test_jagged_tile_patterns.py:N-N]: ...
            jagged_data = tl.load(jagged + v_8 * 1, mask_1[:, :, None], other=0)
            # src[test_jagged_tile_patterns.py:N]: dense_data = dense[tile_b, tile_d, tile_k]
            dense_data = tl.load(dense + (indices_0[:, None, None] * 1024 + indices_3[None, :, None] * 32 + indices_2[None, None, :] * 1), None)
            # src[test_jagged_tile_patterns.py:N]: acc = acc + torch.matmul(jagged_data, dense_data)
            bmm = tl.reshape(tl.dot(tl.reshape(tl.cast(jagged_data, tl.float32), [_BLOCK_SIZE_1, _BLOCK_SIZE_3]), tl.reshape(tl.cast(dense_data, tl.float32), [_BLOCK_SIZE_3, _BLOCK_SIZE_2]), input_precision='tf32', out_dtype=tl.float32), [_BLOCK_SIZE_0, _BLOCK_SIZE_1, _BLOCK_SIZE_2])
            acc = acc_copy_0 + bmm
        # src[test_jagged_tile_patterns.py:N]: bias_data = bias[tile_b, tile_k]
        bias_data = tl.load(bias + (indices_0[:, None] * 32 + indices_2[None, :] * 1), None)
        # src[test_jagged_tile_patterns.py:N]: acc = acc + bias_data.unsqueeze(1)
        unsqueeze = bias_data[:, None, :]
        v_10 = acc + unsqueeze
        # src[test_jagged_tile_patterns.py:N]: [jagged_indices[:, :, None] * K + tile_k.index[None, None, :]],
        subscript_4 = v_4_copy_0[:, :, None]
        v_11 = 32
        v_12 = tl.cast(subscript_4 * v_11, tl.int64)
        subscript_5 = indices_2[None, None, :]
        v_13 = tl.cast(subscript_5, tl.int64)
        v_14 = v_12 + v_13
        # src[test_jagged_tile_patterns.py:N]: hl.store(
        # src[test_jagged_tile_patterns.py:N]:     output,
        # src[test_jagged_tile_patterns.py:N]:     [jagged_indices[:, :, None] * K + tile_k.index[None, None, :]],
        # src[test_jagged_tile_patterns.py:N-N]: ...
        tl.store(output + v_14 * 1, v_10, mask_1[:, :, None])

def jagged_dense_bmm(seq_offsets: torch.Tensor, jagged: torch.Tensor, dense: torch.Tensor, bias: torch.Tensor | None, *, _launcher=_default_launcher):
    # src[test_jagged_tile_patterns.py:N]: L, D = jagged.shape
    L, D = jagged.shape
    # src[test_jagged_tile_patterns.py:N]: B, D, K = dense.shape
    B, D, K = dense.shape
    # src[test_jagged_tile_patterns.py:N]: dtype = torch.promote_types(jagged.dtype, dense.dtype)
    dtype = torch.promote_types(jagged.dtype, dense.dtype)
    # src[test_jagged_tile_patterns.py:N]: device = jagged.device
    device = jagged.device
    # src[test_jagged_tile_patterns.py:N]: jagged = jagged.view(-1)
    jagged = jagged.view(-1)
    # src[test_jagged_tile_patterns.py:N]: output = torch.empty((L, K), dtype=dtype, device=device).view(-1)
    output = torch.empty((L, K), dtype=dtype, device=device).view(-1)
    # src[test_jagged_tile_patterns.py:N]: for tile_b in hl.tile(B):
    _NUM_SM = helion.runtime.get_num_sm(seq_offsets.device)
    # src[test_jagged_tile_patterns.py:N]: for tile_len in hl.jagged_tile(seq_len):
    # src[test_jagged_tile_patterns.py:N]:     jagged_indices = starts[:, None] + tile_len.index[None, :]
    # src[test_jagged_tile_patterns.py:N-N]: ...
    _BLOCK_SIZE_1 = 32
    # src[test_jagged_tile_patterns.py:N]: for tile_k in hl.tile(0, K):
    # src[test_jagged_tile_patterns.py:N]:     acc = hl.zeros([tile_b, tile_len, tile_k], dtype=dtype, device=device)
    # src[test_jagged_tile_patterns.py:N]:     for tile_d in hl.tile(0, D):
    # src[test_jagged_tile_patterns.py:N-N]: ...
    _BLOCK_SIZE_2 = 32
    # src[test_jagged_tile_patterns.py:N]: for tile_b in hl.tile(B):
    # src[test_jagged_tile_patterns.py:N]:     starts = seq_offsets[tile_b]
    # src[test_jagged_tile_patterns.py:N]:     ends = seq_offsets[tile_b.index + 1]
    # src[test_jagged_tile_patterns.py:N-N]: ...
    _group_tile_prefix = torch.empty(3 + 1, dtype=torch.int64, device=seq_offsets.device)
    _group_tile_prefix[0] = 0
    for _g in range(3):
        _m_g = int(seq_offsets[_g + 1].item()) - int(seq_offsets[_g].item())
        _group_tile_prefix[_g + 1] = _group_tile_prefix[_g] + (_m_g + _BLOCK_SIZE_1 - 1) // _BLOCK_SIZE_1 * ((32 + _BLOCK_SIZE_2 - 1) // _BLOCK_SIZE_2)
    _TOTAL_TILES = int(_group_tile_prefix[-1].item())
    _launcher(_helion_jagged_dense_bmm, (_NUM_SM,), seq_offsets, jagged, dense, bias, output, _group_tile_prefix, _NUM_SM, _TOTAL_TILES, num_warps=4, num_stages=1)
    # src[test_jagged_tile_patterns.py:N]: return output.reshape(L, K)
    return output.reshape(L, K)
