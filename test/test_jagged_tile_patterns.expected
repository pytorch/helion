        # src[test_jagged_tile_patterns.py:N]:     acc = hl.zeros([tile_b, tile_len, tile_k], dtype=dtype, device=device)
        # src[test_jagged_tile_patterns.py:N]:     for tile_d in hl.tile(0, D):
        # src[test_jagged_tile_patterns.py:N-N]: ...
        for offset_2 in tl.range(0, 32, _BLOCK_SIZE_2):
            indices_2 = offset_2 + tl.arange(0, _BLOCK_SIZE_2).to(tl.int32)
            v_4_copy = v_4
            v_4_copy_0 = v_4_copy
            # src[test_jagged_tile_patterns.py:N]: acc = hl.zeros([tile_b, tile_len, tile_k], dtype=dtype, device=device)
            acc = tl.full([_BLOCK_SIZE_0, _BLOCK_SIZE_1, _BLOCK_SIZE_2], 0.0, tl.float32)
            # src[test_jagged_tile_patterns.py:N]: for tile_d in hl.tile(0, D):
            # src[test_jagged_tile_patterns.py:N]:     jagged_data = hl.load(
            # src[test_jagged_tile_patterns.py:N]:         jagged,
            # src[test_jagged_tile_patterns.py:N-N]: ...
            for offset_3 in tl.range(0, 32, _BLOCK_SIZE_3):
                indices_3 = offset_3 + tl.arange(0, _BLOCK_SIZE_3).to(tl.int32)
                v_4_copy_0_copy = v_4_copy_0
                acc_copy = acc
                v_4_copy_0_copy_0 = v_4_copy_0_copy
                acc_copy_0 = acc_copy
                # src[test_jagged_tile_patterns.py:N]: [jagged_indices[:, :, None] * D + tile_d.index[None, None, :]],
                subscript_2 = v_4_copy_0_copy_0[:, :, None]
