    offset_0 = pid_0 * _BLOCK_SIZE_0
    indices_0 = (offset_0 + tl.arange(0, _BLOCK_SIZE_0)).to(tl.int32)
    mask_0 = indices_0 < 3
    # src[test_jagged_tile_patterns.py:N]: starts = seq_offsets[tile_b]
    starts = tl.load(seq_offsets + indices_0 * 1, mask_0, other=0)
    # src[test_jagged_tile_patterns.py:N]: ends = seq_offsets[tile_b.index + 1]
    v_0 = 1
    v_1 = indices_0 + v_0
    ends = tl.load(seq_offsets + (indices_0 + 1) * 1, mask_0, other=0)
    # src[test_jagged_tile_patterns.py:N]: seq_len = ends - starts
    v_2 = ends - starts
    # src[test_jagged_tile_patterns.py:N]: for tile_len in hl.jagged_tile(seq_len):
    # src[test_jagged_tile_patterns.py:N]:     jagged_indices = starts[:, None] + tile_len.index[None, :]
    # src[test_jagged_tile_patterns.py:N-N]: ...
    _mask_to = tl.where(mask_0, v_2, -9223372036854775808)
    amax = tl.cast(tl.max(_mask_to, 0), tl.int64)
    for offset_1 in tl.range(0, tl.cast(amax, tl.int32), _BLOCK_SIZE_1):
        indices_1 = offset_1 + tl.arange(0, _BLOCK_SIZE_1).to(tl.int32)
        mask_1 = indices_1[None, :] < v_2[:, None]
        starts_copy = starts
        starts_copy_0 = starts_copy
        # src[test_jagged_tile_patterns.py:N]: jagged_indices = starts[:, None] + tile_len.index[None, :]
        subscript = starts_copy_0[:, None]
        subscript_1 = indices_1[None, :]
        v_3 = tl.cast(subscript_1, tl.int64)
        v_4 = subscript + v_3
