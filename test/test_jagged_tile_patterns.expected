            # src[test_jagged_tile_patterns.py:N-N]: ...
            tl.store(output + v_14 * 1, v_10, mask_1[:, :, None])

def jagged_dense_bmm(seq_offsets: torch.Tensor, jagged: torch.Tensor, dense: torch.Tensor, bias: torch.Tensor | None, *, _launcher=_default_launcher):
    # src[test_jagged_tile_patterns.py:N]: L, D = jagged.shape
    L, D = jagged.shape
    # src[test_jagged_tile_patterns.py:N]: B, D, K = dense.shape
    B, D, K = dense.shape
    # src[test_jagged_tile_patterns.py:N]: dtype = torch.promote_types(jagged.dtype, dense.dtype)
    dtype = torch.promote_types(jagged.dtype, dense.dtype)
    # src[test_jagged_tile_patterns.py:N]: device = jagged.device
