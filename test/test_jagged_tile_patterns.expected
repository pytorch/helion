    # src[test_jagged_tile_patterns.py:N]:     ends = seq_offsets[tile_b.index + 1]
    # src[test_jagged_tile_patterns.py:N-N]: ...
    _launcher(_helion_jagged_dense_bmm, (3,), seq_offsets, jagged, dense, bias, output, num_warps=4, num_stages=1)
