        # src[test_jagged_tile_patterns.py:N]:     jagged_data = hl.load(
        # src[test_jagged_tile_patterns.py:N]:         jagged,
        # src[test_jagged_tile_patterns.py:N-N]: ...
        for offset_3 in tl.range(0, 32, _BLOCK_SIZE_3):
            indices_3 = offset_3 + tl.arange(0, _BLOCK_SIZE_3).to(tl.int32)
            v_4_copy_0_copy = v_4_copy_0
            acc_copy = acc
