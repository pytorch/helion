            subscript_2 = v_4_copy_0_copy_0[:, :, None]
            v_5 = 32
            v_6 = tl.cast(subscript_2 * v_5, tl.int64)
            subscript_3 = indices_3[None, None, :]
            v_7 = tl.cast(subscript_3, tl.int64)
