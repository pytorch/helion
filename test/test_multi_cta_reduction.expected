from __future__ import annotations

import torch
import triton
import triton.language as tl
from helion.runtime import default_launcher as _default_launcher
import triton.language.extra.tlx as tlx

_BLOCK_SIZE_0 = tl.constexpr(8)

@triton.jit
def _helion_layer_norm_fwd(x, out, eps, _RDIM_SIZE_1: tl.constexpr):
    # src[test_multi_cta_reduction.py:N]: def layer_norm_fwd(
    # src[test_multi_cta_reduction.py:N]:     x: torch.Tensor, eps: float = 1e-5
    # src[test_multi_cta_reduction.py:N]: ) -> torch.Tensor:
    # src[test_multi_cta_reduction.py:N-N]: ...
    cta_rank = tlx.cluster_cta_rank()
    barriers = tlx.alloc_barriers(num_barriers=1)
    tlx.barrier_expect_bytes(barriers[0], size=128 * 4 * (2 - 1))
    tlx.cluster_barrier()
    # src[test_multi_cta_reduction.py:N]: for tile_m in hl.tile(m):
    pid_0 = tl.program_id(0)
    offset_0 = pid_0 * _BLOCK_SIZE_0
    indices_0 = (offset_0 + tl.arange(0, _BLOCK_SIZE_0)).to(tl.int32)
    indices_1 = tl.arange(0, _RDIM_SIZE_1).to(tl.int32)
    indices_1 = cta_rank * (1024 // 2) + indices_1 % (1024 // 2)
    # src[test_multi_cta_reduction.py:N]: acc = x[tile_m, :].to(torch.float32)
    load = tl.load(x + (indices_0[:, None] * 1024 + indices_1[None, :] * 1), None)
    v_0 = tl.cast(load, tl.float32)
    # src[test_multi_cta_reduction.py:N]: mean_val = torch.sum(acc, dim=-1) / n
    dsm_local = tl.sum(v_0, 1)
    dsm_buf = tlx.local_alloc((_BLOCK_SIZE_0,), tl.float32, 2)
    tlx.local_store(dsm_buf[cta_rank], dsm_local)
    for dsm_i in tl.static_range(2):
        if cta_rank != dsm_i:
            tlx.async_remote_shmem_store(dsm_buf[cta_rank], dsm_local, dsm_i, barriers[0])
    tlx.barrier_wait(barriers[0], phase=0)
    dsm_global = tl.zeros((_BLOCK_SIZE_0,), dtype=tl.float32)
    for dsm_acc_i in tl.static_range(2):
        dsm_global += tlx.local_load(tlx.local_view(dsm_buf, dsm_acc_i))
    sum_1 = tl.cast(dsm_global, tl.float32)
    v_1 = 0.0009765625
    v_2 = sum_1 * v_1
    # src[test_multi_cta_reduction.py:N]: centered = acc - mean_val[:, None]
    subscript = v_2[:, None]
    v_3 = v_0 - subscript
    # src[test_multi_cta_reduction.py:N]: var_val = torch.sum(centered * centered, dim=-1) / n
    v_4 = v_3 * v_3
    dsm_local_1 = tl.sum(v_4, 1)
    dsm_buf_1 = tlx.local_alloc((_BLOCK_SIZE_0,), tl.float32, 2)
    tlx.local_store(dsm_buf_1[cta_rank], dsm_local_1)
    for dsm_i_1 in tl.static_range(2):
        if cta_rank != dsm_i_1:
            tlx.async_remote_shmem_store(dsm_buf_1[cta_rank], dsm_local_1, dsm_i_1, barriers[0])
    tlx.barrier_wait(barriers[0], phase=0)
    dsm_global_1 = tl.zeros((_BLOCK_SIZE_0,), dtype=tl.float32)
    for dsm_acc_i_1 in tl.static_range(2):
        dsm_global_1 += tlx.local_load(tlx.local_view(dsm_buf_1, dsm_acc_i_1))
    sum_2 = tl.cast(dsm_global_1, tl.float32)
    v_5 = 0.0009765625
    v_6 = sum_2 * v_5
    # src[test_multi_cta_reduction.py:N]: rstd_val = torch.rsqrt(var_val + eps)
    v_7 = v_6 + eps
    v_8 = tl.rsqrt(v_7)
    # src[test_multi_cta_reduction.py:N]: out[tile_m, :] = (centered * rstd_val[:, None]).to(x.dtype)
    subscript_1 = v_8[:, None]
    v_9 = v_3 * subscript_1
    v_10 = tl.cast(v_9, tl.float16)
    tl.store(out + (indices_0[:, None] * 1024 + indices_1[None, :] * 1), v_10, None)

def layer_norm_fwd(x: torch.Tensor, eps: float=1e-05, *, _launcher=_default_launcher):
    # src[test_multi_cta_reduction.py:N]: m, n = x.size()
    m, n = x.size()
    # src[test_multi_cta_reduction.py:N]: out = torch.empty_like(x)
    out = torch.empty_like(x)
    # src[test_multi_cta_reduction.py:N]: for tile_m in hl.tile(m):
    _BLOCK_SIZE_0 = 8
    _RDIM_SIZE_1 = 1024
    # src[test_multi_cta_reduction.py:N]: for tile_m in hl.tile(m):
    # src[test_multi_cta_reduction.py:N]:     acc = x[tile_m, :].to(torch.float32)
    # src[test_multi_cta_reduction.py:N]:     mean_val = torch.sum(acc, dim=-1) / n
    # src[test_multi_cta_reduction.py:N-N]: ...
    _launcher(_helion_layer_norm_fwd, (triton.cdiv(128, _BLOCK_SIZE_0),), x, out, eps, _RDIM_SIZE_1, num_warps=4, num_stages=1, ctas_per_cga=(1, 2, 1))
    # src[test_multi_cta_reduction.py:N]: return out
    return out
