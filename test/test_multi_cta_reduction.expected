from __future__ import annotations

import torch
import triton
import triton.language as tl
from helion.runtime import default_launcher as _default_launcher
import triton.language.extra.tlx as tlx

_BLOCK_SIZE_0 = tl.constexpr(8)

@triton.jit
def _helion_simple_reduce(x, out, _RDIM_SIZE_1: tl.constexpr):
    # src[test_multi_cta_reduction.py:N]: def simple_reduce(x: torch.Tensor) -> torch.Tensor:
    # src[test_multi_cta_reduction.py:N]:     m, n = x.size()
    # src[test_multi_cta_reduction.py:N]:     out = torch.empty([m], device=x.device, dtype=torch.float32)
    # src[test_multi_cta_reduction.py:N-N]: ...
    cta_rank = tlx.cluster_cta_rank()
    barriers = tlx.alloc_barriers(num_barriers=1)
    tlx.barrier_expect_bytes(barriers[0], size=128 * 4 * (4 - 1))
    tlx.cluster_barrier()
    # src[test_multi_cta_reduction.py:N]: for tile_m in hl.tile(m):
    pid_0 = tl.program_id(0)
    offset_0 = pid_0 * _BLOCK_SIZE_0
    indices_0 = (offset_0 + tl.arange(0, _BLOCK_SIZE_0)).to(tl.int32)
    indices_1 = tl.arange(0, _RDIM_SIZE_1).to(tl.int32)
    indices_1 = cta_rank * (4096 // 4) + indices_1 % (4096 // 4)
    # src[test_multi_cta_reduction.py:N]: x[tile_m, :].to(torch.float32), dim=-1
    load = tl.load(x + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), None)
    v_0 = tl.cast(load, tl.float32)
    # src[test_multi_cta_reduction.py:N]: out[tile_m] = torch.sum(
    # src[test_multi_cta_reduction.py:N]:     x[tile_m, :].to(torch.float32), dim=-1
    # src[test_multi_cta_reduction.py:N]: )
    dsm_local = tl.sum(v_0, 1)
    dsm_buf = tlx.local_alloc((_BLOCK_SIZE_0,), tl.float32, 4)
    tlx.local_store(dsm_buf[cta_rank], dsm_local)
    for dsm_i in tl.static_range(4):
        if cta_rank != dsm_i:
            tlx.async_remote_shmem_store(dsm_buf[cta_rank], dsm_local, dsm_i, barriers[0])
    tlx.barrier_wait(barriers[0], phase=0)
    dsm_global = tl.zeros((_BLOCK_SIZE_0,), dtype=tl.float32)
    for dsm_acc_i in tl.static_range(4):
        dsm_global += tlx.local_load(tlx.local_view(dsm_buf, dsm_acc_i))
    sum_1 = tl.cast(dsm_global, tl.float32)
    tl.store(out + indices_0 * 1, sum_1, None)

def simple_reduce(x: torch.Tensor, *, _launcher=_default_launcher):
    # src[test_multi_cta_reduction.py:N]: m, n = x.size()
    m, n = x.size()
    # src[test_multi_cta_reduction.py:N]: out = torch.empty([m], device=x.device, dtype=torch.float32)
    out = torch.empty([m], device=x.device, dtype=torch.float32)
    # src[test_multi_cta_reduction.py:N]: for tile_m in hl.tile(m):
    _BLOCK_SIZE_0 = 8
    _RDIM_SIZE_1 = 4096
    # src[test_multi_cta_reduction.py:N]: for tile_m in hl.tile(m):
    # src[test_multi_cta_reduction.py:N]:     out[tile_m] = torch.sum(
    # src[test_multi_cta_reduction.py:N]:         x[tile_m, :].to(torch.float32), dim=-1
    # src[test_multi_cta_reduction.py:N-N]: ...
    _launcher(_helion_simple_reduce, (triton.cdiv(64, _BLOCK_SIZE_0),), x, out, _RDIM_SIZE_1, num_warps=4, num_stages=1, ctas_per_cga=(1, 4, 1))
