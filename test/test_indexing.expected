@triton.jit
def _helion_advanced_indexing_kernel(x, index_i, index_j, out, _RDIM_SIZE_1: tl.constexpr, _RDIM_SIZE_2: tl.constexpr):
    indices_1 = tl.arange(0, _RDIM_SIZE_1).to(tl.int32)
