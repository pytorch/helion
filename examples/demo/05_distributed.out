from __future__ import annotations

import torch
import helion.language as hl
import triton
import triton.language as tl
from torch._inductor.runtime.triton_compat import libdevice
from helion.runtime import default_launcher as _default_launcher

import __main__ as _source_module

@triton.jit
def symm_mem_sync(signal_pad_ptrs, block_id, rank: tl.constexpr, world_size: tl.constexpr, hasPreviousMemAccess: tl.constexpr=False, hasSubsequentMemAccess: tl.constexpr=False) -> None:
    """
    Synchronizes blocks with matching block_id across participating devices.

    Note: the function itself is not a system level barrier/fence. It is a
    building block for expressing different synchronization patterns.

    Pattern 0: Ensures that all writes to symm_mem buffers from previous
    kernels across all devices are visible to the current kernel:

        symm_mem_sync(..., hasPreviousMemAccess=False, hasSubsequentMemAccess=True)

    Pattern 1: Ensures that all writes to symm_mem buffers from the current
    block are visible to all remote blocks with matching blockIdx:

        symm_mem_sync(..., hasPreviousMemAccess=True, hasSubsequentMemAccess=True)

    Pattern 2: Ensures that symm_mem buffers read by the current kernel are safe
    for writing by subsequent kernels across all devices.

        symm_mem_sync(..., hasPreviousMemAccess=True, hasSubsequentMemAccess=False)

    CUDA graph friendliness:

        This barrier operates through atomic operations on a zero-filled signal
        pad, which resets to a zero-filled state after each successful
        synchronization. This design eliminates the need for incrementing a
        flag from host.
    """
    # src[05_distributed.py:48]: if "LOCAL_RANK" in os.environ:
    # src[05_distributed.py:49]:     import torch.distributed as dist
    if block_id is None:
        # src[05_distributed.py:49]: import torch.distributed as dist
        block_id = _get_flat_bid()
    # src[05_distributed.py:50]: import torch.distributed._symmetric_memory as symm_mem
    flat_tid = _get_flat_tid()
    # src[05_distributed.py:52]: rank = int(os.environ["LOCAL_RANK"])
    remote_ranks = tl.arange(0, world_size)
    # src[05_distributed.py:53]: torch.manual_seed(42 + rank)
    signal_pad_ptrs = signal_pad_ptrs.to(tl.pointer_type(tl.uint64))
    # src[05_distributed.py:54]: device = torch.device(f"cuda:{rank}")
    # src[05_distributed.py:55]: torch.cuda.set_device(device)
    # src[05_distributed.py:56]: dist.init_process_group("nccl")
    remote_signal_pad_addrs = tl.load(signal_pad_ptrs + remote_ranks).to(tl.pointer_type(tl.uint32))
    # src[05_distributed.py:57]: group = dist.group.WORLD
    send_addrs = remote_signal_pad_addrs + block_id * world_size + rank
    # src[05_distributed.py:59]: symm_mem.enable_symm_mem_for_group(group.group_name)  # pyrefly: ignore [deprecated]
    # src[05_distributed.py:61]: N, D = 128, 4096
    local_signal_pad_addr = tl.load(signal_pad_ptrs + rank).to(tl.pointer_type(tl.uint32))
    # src[05_distributed.py:62]: x = torch.randn(N, D, device=device, dtype=torch.bfloat16)
    wait_addrs = local_signal_pad_addr + block_id * world_size + remote_ranks
    # src[05_distributed.py:64]: buf = symm_mem.empty(N, D, dtype=x.dtype, device=device)
    # src[05_distributed.py:65]: hdl = symm_mem.rendezvous(buf, group.group_name)
    if hasPreviousMemAccess:
        # src[05_distributed.py:65]: hdl = symm_mem.rendezvous(buf, group.group_name)
        tl.debug_barrier()
    # src[05_distributed.py:67]: result = allreduce_rmsnorm(buf, x, weight, hdl.signal_pad_ptrs_dev,
    # src[05_distributed.py:68]:                            EPS=1e-5, RANK=hdl.rank,
    # src[05_distributed.py:69]:                            WORLD_SIZE=hdl.world_size, GROUP_NAME=group.group_name)
    if flat_tid < world_size:
        # src[05_distributed.py:68]: EPS=1e-5, RANK=hdl.rank,
        _send_signal(send_addrs, 'release' if hasPreviousMemAccess else 'relaxed')
        # src[05_distributed.py:69]: WORLD_SIZE=hdl.world_size, GROUP_NAME=group.group_name)
        _wait_signal(wait_addrs, 'acquire' if hasSubsequentMemAccess else 'relaxed')
    # src[05_distributed.py:71]: x_ref = x.clone()
    # src[05_distributed.py:72]: dist.all_reduce(x_ref)
    if hasSubsequentMemAccess:
        # src[05_distributed.py:72]: dist.all_reduce(x_ref)
        tl.debug_barrier()

@triton.jit
def _get_flat_bid():
    # src[05_distributed.py:76]: torch.testing.assert_close(result, expected, atol=0.1, rtol=0.1)
    # src[05_distributed.py:77]: if rank == 0:
    # src[05_distributed.py:78]:     print("Correctness: PASSED")
    # src[05_distributed.py:76-80]: ...
    return tl.program_id(2) * tl.num_programs(1) * tl.num_programs(0) + tl.program_id(1) * tl.num_programs(0) + tl.program_id(0)

@triton.jit
def _get_flat_tid():
    # src[05_distributed.py:84]: env = {**os.environ, "NVSHMEM_BOOTSTRAP_UID_SOCK_IFNAME": "lo",
    tid_x, tid_y, tid_z = _get_tid()
    # src[05_distributed.py:85]: "NCCL_SOCKET_IFNAME": "lo", "HELION_PRINT_OUTPUT_CODE": "1"}
    ntid_x, ntid_y, _ = _get_ntid()
    # src[05_distributed.py:86]: sys.exit(subprocess.run([
    return tid_z * ntid_y * ntid_x + tid_y * ntid_x + tid_x

@triton.jit
def _get_tid():
    # src[05_distributed.py:90]:     "--no_python", sys.executable, __file__,
    # src[05_distributed.py:91]: ], env=env).returncode)
    return tl.inline_asm_elementwise('\n        mov.u32 $0, %tid.x;\n        mov.u32 $1, %tid.y;\n        mov.u32 $2, %tid.z;\n        ', '=r,=r,=r', [], dtype=(tl.uint32, tl.uint32, tl.uint32), is_pure=True, pack=1)

@triton.jit
def _get_ntid():
    # src[05_distributed.py:105]: [source unavailable]
    return tl.inline_asm_elementwise('\n        mov.u32 $0, %ntid.x;\n        mov.u32 $1, %ntid.y;\n        mov.u32 $2, %ntid.z;\n        ', '=r,=r,=r', [], dtype=(tl.uint32, tl.uint32, tl.uint32), is_pure=True, pack=1)

@triton.jit
def _send_signal(addrs, sem: tl.constexpr) -> None:
    # src[05_distributed.py:120]: [source unavailable]
    tl.inline_asm_elementwise(f'\n        {{\n            .reg .u32   %tmp32_<1>;\n            .reg .pred  %p<1>;\n\n            send_signal:\n                atom.global.{sem}.sys.cas.b32 %tmp32_0, [$1], 0, 1;\n                setp.eq.u32 %p0, %tmp32_0, 0;\n                @!%p0 bra send_signal;\n        }}\n        ', '=r, l', [addrs], dtype=addrs.dtype, is_pure=False, pack=1)

@triton.jit
def _wait_signal(addrs, sem: tl.constexpr) -> None:
    # src[05_distributed.py:141]: [source unavailable]
    tl.inline_asm_elementwise(f'\n        {{\n            .reg .u32   %tmp32_<1>;\n            .reg .pred  %p<1>;\n\n            wait_signal:\n                atom.global.sys.{sem}.cas.b32 %tmp32_0, [$1], 1, 0;\n                setp.eq.u32 %p0, %tmp32_0, 1;\n                @!%p0 bra wait_signal;\n        }}\n        ', '=r, l', [addrs], dtype=tl.int32, is_pure=False, pack=1)
_BLOCK_SIZE_0 = tl.constexpr(8)

@triton.jit
def _helion_allreduce_rmsnorm(x, symm_mem_buffer, buffer_tuple_item_0, buffer_tuple_item_1, buffer_tuple_item_2, buffer_tuple_item_3, weight, output, signal_pad_ptrs, _RDIM_SIZE_1: tl.constexpr):
    # src[05_distributed.py:28]: for tile_n in hl.tile(N):
    pid_0 = tl.program_id(0)
    offset_0 = pid_0 * _BLOCK_SIZE_0
    indices_0 = (offset_0 + tl.arange(0, _BLOCK_SIZE_0)).to(tl.int32)
    indices_1 = tl.arange(0, _RDIM_SIZE_1).to(tl.int32)
    # src[05_distributed.py:29]: symm_mem_buffer[tile_n, :] = x[tile_n, :]
    load = tl.load(x + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), None)
    tl.store(symm_mem_buffer + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), load, None)
    # src[05_distributed.py:30]: hl.triton_kernel(symm_mem_sync,
    # src[05_distributed.py:31]:                  args=(signal_pad_ptrs, None, RANK, WORLD_SIZE, True, True),
    # src[05_distributed.py:32]:                  output_like=None)
    symm_mem_sync(signal_pad_ptrs, None, 1, 4, True, True)
    # src[05_distributed.py:34]: acc = hl.zeros([tile_n, D], dtype=torch.float32)
    acc = tl.full([_BLOCK_SIZE_0, 4096], 0.0, tl.float32)
    # src[05_distributed.py:36]: acc = acc + remote[tile_n, :].to(torch.float32)
    load_1 = tl.load(buffer_tuple_item_0 + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), None)
    v_0 = tl.cast(load_1, tl.float32)
    v_1 = acc + v_0
    load_2 = tl.load(buffer_tuple_item_1 + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), None)
    v_2 = tl.cast(load_2, tl.float32)
    v_3 = v_1 + v_2
    load_3 = tl.load(buffer_tuple_item_2 + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), None)
    v_4 = tl.cast(load_3, tl.float32)
    v_5 = v_3 + v_4
    load_4 = tl.load(buffer_tuple_item_3 + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), None)
    v_6 = tl.cast(load_4, tl.float32)
    v_7 = v_5 + v_6
    # src[05_distributed.py:38]: variance = torch.mean(acc * acc, dim=-1, keepdim=True)
    v_8 = v_7 * v_7
    variance_extra = tl.cast(tl.reshape(tl.sum(v_8, 1), [_BLOCK_SIZE_0, 1]), tl.float32)
    v_9 = 4096
    v_10 = tl.cast(v_9, tl.float32)
    v_11 = variance_extra / v_10
    # src[05_distributed.py:39]: output[tile_n, :] = (acc * torch.rsqrt(variance + EPS)  # type: ignore[unsupported-operation]
    v_12 = 1e-05
    v_13 = v_11 + v_12
    v_14 = libdevice.rsqrt(v_13)
    v_15 = v_7 * v_14
    # src[05_distributed.py:40]: * weight[None, :].to(torch.float32)).to(x.dtype)
    load_5 = tl.load(weight + indices_1[None, :] * 1, None)
    v_16 = tl.cast(load_5, tl.float32)
    # src[05_distributed.py:39]: output[tile_n, :] = (acc * torch.rsqrt(variance + EPS)  # type: ignore[unsupported-operation]
    # src[05_distributed.py:40]:                      * weight[None, :].to(torch.float32)).to(x.dtype)
    v_17 = v_15 * v_16
    v_18 = tl.cast(v_17, tl.bfloat16)
    tl.store(output + (indices_0[:, None] * 4096 + indices_1[None, :] * 1), v_18, None)
