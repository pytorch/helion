    x = rand_strided(size=(128, 4096), stride=(4096, 1), dtype=torch.bfloat16, device='cuda:1')
    weight = rand_strided(size=(4096,), stride=(1,), dtype=torch.bfloat16, device='cuda:1')
    signal_pad_ptrs = 140236471411200
